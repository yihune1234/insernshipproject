# Base URL of the Django REST API backend (no trailing slash)
VITE_API_URL=http://localhost:8000/api
VITE_API_BASE_URL=http://localhost:8000/api

# Application name displayed in the UI
VITE_APP_NAME=CredWallet

# Environment identifier
VITE_ENV=development

# ── Mock Org API (development) ────────────────────────────────────────────────
# The included mock_org_api/ Express server lets you test the federated member
# API integration without a real organization backend.
# Start it with:  cd mock_org_api && npm install && npm start
# Then in the Issuer Portal → Member API, set:
#   Base URL:    http://localhost:3001
#   Endpoint:    /api/members/verify
#   Key header:  X-API-Key
#   Key value:   mock-api-key-2024
